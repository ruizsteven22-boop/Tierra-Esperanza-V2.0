// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- AUTENTICACIÓN Y ROLES ---

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique // superadmin, administrador, secretaria, tesoreria, directiva, consulta
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  username     String    @unique
  email        String?   @unique
  passwordHash String
  isActive     Boolean   @default(true)
  roleId       Int
  role         Role      @relation(fields: [roleId], references: [id])
  photoUrl     String?
  
  treasuryTransactions TreasuryTransaction[]
  secretaryRequests    SecretaryRequest[]
  secretaryRecords     SecretaryRecord[]
  secretaryDocuments   SecretaryDocument[]
  assemblyAttendances  AssemblyAttendance[]
  assemblyNotifications AssemblyNotification[]
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([roleId])
}

// --- SOCIOS Y GRUPO FAMILIAR ---

model Member {
  id                  Int                   @id @default(autoincrement())
  name                String
  rut                 String                @unique
  email               String?
  phone               String?
  address             String?
  region              String?
  commune             String?
  status              String                @default("Activo") // Activo, Inactivo, Suspendido
  registroHogarSocial String?
  photoUrl            String?
  notes               String?               @db.Text
  
  familyMembers       FamilyMember[]
  treasuryTransactions TreasuryTransaction[]
  attendances         AssemblyAttendance[]
  secretaryRequests   SecretaryRequest[]
  notifications       AssemblyNotification[]
  directiveMember     DirectiveMember?
  
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([rut])
  @@index([status])
}

model FamilyMember {
  id           Int      @id @default(autoincrement())
  name         String
  rut          String?
  relationship String?  // Conyuge, Hijo, etc.
  memberId     Int
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([memberId])
}

// --- ORGANIZACIÓN Y DIRECTIVA ---

model DirectiveMember {
  id        Int      @id @default(autoincrement())
  memberId  Int      @unique
  role      String   // Presidente, Secretario, Tesorero, etc.
  startDate DateTime
  endDate   DateTime?
  status    String   @default("Activo")
  
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- REUNIONES Y ASAMBLEAS ---

model Meeting {
  id          Int                @id @default(autoincrement())
  title       String
  description String?
  date        DateTime
  location    String?
  minutesUrl  String?
  agreements  MeetingAgreement[]
  
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model Assembly {
  id            Int                    @id @default(autoincrement())
  title         String
  description   String?
  date          DateTime
  location      String?
  type          String                 @default("Ordinaria") // Ordinaria, Extraordinaria
  status        String                 @default("Programada") // Programada, Realizada, Cancelada
  minutesUrl    String?
  
  attendances   AssemblyAttendance[]
  notifications AssemblyNotification[]
  agreements    MeetingAgreement[]
  
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model AssemblyAttendance {
  id            Int      @id @default(autoincrement())
  assemblyId    Int
  memberId      Int
  rut           String?  // RUT registrado al momento de la asistencia
  status        String   @default("presente") // presente, ausente, justificado
  notes         String?  @db.Text
  registeredAt  DateTime @default(now())
  userId        Int?     // Usuario que registró la asistencia

  assembly     Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([assemblyId, memberId])
  @@index([assemblyId])
  @@index([memberId])
  @@index([userId])
}

model AssemblyNotification {
  id           Int      @id @default(autoincrement())
  assemblyId   Int
  memberId     Int
  channel      String   // email, whatsapp
  destination  String   // correo o numero
  subject      String?
  message      String   @db.Text
  status       String   @default("pendiente") // pendiente, enviado, error
  sentAt       DateTime?
  errorMessage String?  @db.Text
  userId       Int?     // Usuario que envió la notificación

  assembly     Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([assemblyId])
  @@index([memberId])
  @@index([userId])
}

model MeetingAgreement {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  responsible String?
  status      String    @default("pendiente") // pendiente, en_proceso, cumplido
  dueDate     DateTime?
  meetingId   Int?
  assemblyId  Int?

  meeting     Meeting?  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  assembly    Assembly? @relation(fields: [assemblyId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([meetingId])
  @@index([assemblyId])
}

// --- TESORERÍA ---

model TreasuryCategory {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  type        String               @default("INGRESO") // INGRESO, EGRESO
  description String?
  transactions TreasuryTransaction[]
  
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model TreasuryTransaction {
  id            Int               @id @default(autoincrement())
  type          String            // INGRESO, EGRESO
  amount        Decimal
  description   String
  paymentMethod String?           // Efectivo, Transferencia, etc.
  date          DateTime          @default(now())
  receiptNumber String?           @unique
  receiptUrl    String?
  notes         String?
  categoryId    Int?
  memberId      Int?
  userId        Int?              // Usuario que registró la transacción

  category      TreasuryCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  member        Member?           @relation(fields: [memberId], references: [id], onDelete: SetNull)
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  receipt       TreasuryReceipt?

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([categoryId])
  @@index([memberId])
  @@index([userId])
  @@index([type])
}

model TreasuryReceipt {
  id             Int                @id @default(autoincrement())
  transactionId  Int                @unique
  number         Int                @unique // Número correlativo de recibo
  issueDate      DateTime           @default(now())
  pdfUrl         String?
  sentByEmail    Boolean            @default(false)
  sentByWhatsapp Boolean            @default(false)
  memberId       Int?
  amount         Decimal?
  details        String?            @db.Text
  
  transaction    TreasuryTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([memberId])
}

// --- SECRETARÍA ---

model SecretaryRequest {
  id          Int                @id @default(autoincrement())
  title       String
  type        String             @default("Solicitud") // Certificado, Solicitud, Otro
  description String?
  status      String             @default("pendiente") // pendiente, en_proceso, resuelto, rechazado
  priority    String             @default("Normal")    // Normal, Alta, Urgente
  memberId    Int
  userId      Int?               // Usuario que creó la solicitud
  
  member      Member             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  documents   SecretaryDocument[]
  records     SecretaryRecord[]
  
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([memberId])
  @@index([userId])
  @@index([status])
}

model SecretaryDocument {
  id          Int               @id @default(autoincrement())
  requestId   Int?
  title       String
  type        String
  folio       String            @unique
  fileUrl     String?
  status      String            @default("Borrador")
  userId      Int?              // Usuario que creó el documento
  
  request     SecretaryRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([requestId])
  @@index([userId])
}

model SecretaryRecord {
  id          Int               @id @default(autoincrement())
  requestId   Int
  note        String
  status      String?
  userId      Int?              // Usuario que realizó el registro
  
  request     SecretaryRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime          @default(now())

  @@index([requestId])
  @@index([userId])
}

// --- CONFIGURACIÓN GLOBAL ---

model SystemConfig {
  id                    Int      @id @default(1) // Siempre ID 1
  committeeName         String
  logoUrl               String?
  address               String?
  phone                 String?
  email                 String?
  region                String?
  commune               String?
  representativeName    String?
  signatureUrl          String?
  documentFooter        String?  @db.Text
  receiptFooter         String?  @db.Text
  assemblyMessageTemplate String? @db.Text
  emailSenderName       String?
  emailSenderAddress    String?
  whatsappContact       String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
